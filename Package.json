{
    "name": "softbrainchat",
    "version": "1.0.0",
    "description": "SoftBrainChat — AI Chat + Meta Auto-Reply SaaS",
    "private": true,
    "scripts": {
        "dev": "concurrently \"npm run server\" \"npm run client\" --names \"SERVER,CLIENT\" --prefix-colors \"cyan,magenta\"",
        "server": "npm run dev --prefix server",
        "client": "npm run dev --prefix client",
        "build": "npm run build --prefix client",
        "install:all": "npm install && npm install --prefix client && npm install --prefix server",
        "start": "npm run start --prefix server"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}
